# Bright Data Scrapers collector API — required when scrape.provider is
# "brightdata" in config.yaml (the default). Account API key from
# https://brightdata.com/cp/setting/api_tokens
# Free tier: 5,000 credits/month (1 credit = 1 record), renews monthly.
BRIGHTDATA_API_KEY=

# ID of your Bright Data Scrapers collector (built in Scraper Studio from the
# Idealista search URL). Looks like c_xxxxxxxxxxxxxxxx. Takes precedence over
# scrape.brightdata_collector_id in config.yaml.
BRIGHTDATA_COLLECTOR_ID=

# ScrapeOps Proxy Aggregator — required when scrape.provider is "scrapeops"
# (fallback path), and used by the optional detail-page fetch (scrape.fetch_details).
# Sign up at https://scrapeops.io/ → Dashboard → copy your API key.
# Uses bypass=datadome (40 credits/request, one request per results page).
SCRAPEOPS_API_KEY=

# Telegram bot notifications (optional — leave blank to disable)
# 1. Talk to @BotFather on Telegram → /newbot → copy the token below
# 2. Send any message to your bot, then visit:
#    https://api.telegram.org/bot<TOKEN>/getUpdates  → copy chat.id
TELEGRAM_BOT_TOKEN=

TELEGRAM_CHAT_ID=

# OpenAI API for Property AI Analyst and Telegram chat agent (optional)
# Sign up at https://platform.openai.com/ → API keys → Create key
OPENAI_API_KEY=

# Property AI Analyst model override (default: gpt-5.4-mini)
# Uses reasoning mode for detailed property analysis (~$0.001/property)
SCOUT_ANALYST_MODEL=gpt-5.4-mini

# Telegram chat agent model override (default: gpt-5-nano)
# Answers /start, /help, and general chat messages to the Telegram bot
SCOUT_CHAT_MODEL=gpt-5-nano

# Database path override (default: data/scout.db relative to project root)
SCOUT_DB_PATH=

# Log directory override (default: logs relative to project root)
SCOUT_LOG_DIR=
